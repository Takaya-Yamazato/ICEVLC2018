---
const today = new Date();
import HeaderLink from './HeaderLink.astro';
---
<hr class="border-slate-300" />
<footer>
	
	&copy; {today.getFullYear()} Takaya Yamazato. All rights reserved.
<div class="max-w-4xl mx-auto p-6">
				<HeaderLink href="/index2">Home</HeaderLink>
			<HeaderLink href="/photos">Commemorative photos</HeaderLink>
			<a href="https://yamazato.nuee.nagoya-u.ac.jp/en/Image-sensor-communication/" target="_blank" class="hover:text-blue-600">Image Sensor Communication at Yamazato Lab.</a>

</div>

</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	a {
		padding: 0.5em 1em ;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
